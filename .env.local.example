# Copy this file to ".env.local" and fill in real values.
# .env.local is git-ignored, so your credentials stay private.

# --- SMTP (email sending) ---
# Defaults below work for Gmail. For Gmail you MUST use an "App Password"
# (https://myaccount.google.com/apppasswords), NOT your normal password.
# App Passwords require 2-Step Verification to be enabled on the account.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password

# --- Stats counters (required on Vercel) ---
# Add the Upstash Redis integration in the Vercel dashboard (Storage / Marketplace),
# or create a database at https://console.upstash.com and paste the REST credentials.
# Without these, visit/download counts reset on every serverless invocation in production.
#
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
#
# If you migrated from legacy Vercel KV, these names also work:
# KV_REST_API_URL=https://your-endpoint.upstash.io
# KV_REST_API_TOKEN=your-token

# --- Site URL (optional) ---
# Used for Open Graph / metadata when not on Vercel.
# NEXT_PUBLIC_SITE_URL=https://martin-guthrie-gis.vercel.app
